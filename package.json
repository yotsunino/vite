{
  "name": "vite",
  "version": "5.0.0",
  "description": "Next generation frontend tooling. It's fast!",
  "type": "module",
  "license": "MIT",
  "author": "Evan You",
  "homepage": "https://vitejs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitejs/vite.git",
    "directory": "packages/vite"
  },
  "keywords": [
    "frontend",
    "hmr",
    "dev-server",
    "build-tool",
    "vite"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r --filter=./packages/* run dev",
    "build": "pnpm -r --filter=./packages/* run build",
    "typecheck": "pnpm -r --filter=./packages/* run typecheck",
    "test": "pnpm run test-unit && pnpm run test-serve && pnpm run test-build",
    "test-serve": "vitest run",
    "test-build": "VITE_TEST_BUILD=1 vitest run",
    "test-unit": "vitest run packages/vite/src",
    "test-docs": "pnpm run build-docs",
    "lint": "eslint --cache --ext .ts packages/*/src/**",
    "lint:fix": "eslint --cache --fix --ext .ts packages/*/src/**",
    "format": "prettier --write --cache 'packages/**/*.{ts,js,json,md}'",
    "format:check": "prettier --check --cache 'packages/**/*.{ts,js,json,md}'",
    "release": "node scripts/release.mjs",
    "ci-publish": "node scripts/publishCI.mjs",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^8.55.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "execa": "^8.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "packageManager": "pnpm@8.11.0"
}
